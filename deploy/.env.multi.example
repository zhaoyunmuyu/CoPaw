# CoPaw Multi-Instance Docker Compose Environment
# Copy this file to .env.multi and customize values

# Redis Configuration
COPAW_REDIS_HOST=redis
COPAW_REDIS_PORT=6379

# Cron Lock Configuration (for distributed cron coordination)
COPAW_CRON_LOCK_TTL=600
COPAW_CRON_LOCK_JITTER_MS=2000

# NAS Volume Mount Point
# Adjust this to match your NAS mount point
NAS_MOUNT_POINT=/mnt/nas/copaw

# CoPaw Instance Count
# Adjust the 'replicas' value in docker-compose.multi.yml
# or use: docker-compose -f docker-compose.multi.yml up --scale copaw=N
COPAW_REPLICAS=5

# Nginx Port (external access)
NGINX_PORT=8088

# Redis Memory Limit
REDIS_MAXMEMORY=256mb